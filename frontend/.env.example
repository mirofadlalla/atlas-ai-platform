# Atlas AI Frontend - Environment Configuration
# Copy this file to .env and update with your values

# Backend API Configuration
REACT_APP_API_URL=http://localhost:8000/api

# Feature Flags
REACT_APP_ENABLE_RERANKING=true
REACT_APP_ENABLE_EVALUATION=true
REACT_APP_ENABLE_ANALYTICS=true

# Authentication
REACT_APP_AUTH_TIMEOUT_MINUTES=30

# UI Configuration
REACT_APP_ITEMS_PER_PAGE=10
REACT_APP_MAX_UPLOAD_SIZE_MB=100

# MLflow Dashboard (optional)
REACT_APP_MLFLOW_DASHBOARD_URL=http://localhost:5000

# Deployment (optional)
REACT_APP_ENVIRONMENT=development
